generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String?  @unique
  phone     String?  @unique
  password  String
  role      String
  salonId   Int?
  salon     Salon?   @relation(fields: [salonId], references: [id])
  createdAt DateTime @default(now())
  queues   Queue[]
  bookings Booking[]
}

model Salon {
  id           Int     @id @default(autoincrement())
  salonName    String
  ownerName    String
  address      String
  phone        String @unique
  imageUrl     String?
  isOpen       Boolean @default(true)
  currentToken Int     @default(0)

  users    User[]
  services Service[]
  queues   Queue[]
  bookings Booking[]
}

model Service {
  id       Int    @id @default(autoincrement())
  salonId  Int
  name     String
  duration Int
  price    Float?

  salon  Salon   @relation(fields: [salonId], references: [id])
  queues Queue[]
  bookings Booking[]
}

model Queue {
  id                 Int       @id @default(autoincrement())

  userId             Int
  salonId            Int
  serviceId          Int

  tokenNumber        Int
  status             String

  joinedAt           DateTime  @default(now())
  estimatedStartTime DateTime?

  user               User      @relation(fields: [userId], references: [id])
  salon              Salon     @relation(fields: [salonId], references: [id])
  service            Service   @relation(fields: [serviceId], references: [id])
}

model OtpVerification {
  id        Int      @id @default(autoincrement())
  phone     String   @unique
  otp       String
  expiresAt DateTime
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  phone     String
  tokenHash String
  revoked   Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model PendingSalon {
  id          Int      @id @default(autoincrement())
  name        String
  saloon_name String
  address     String
  imageUrl    String?
  phone       String   @unique
  createdAt   DateTime @default(now())
}



model Booking {
  id          Int      @id @default(autoincrement())
  userId      Int
  salonId     Int
  serviceId   Int
  bookingTime DateTime
  status      String
  createdAt   DateTime @default(now())
  
  user    User    @relation(fields: [userId], references: [id])
  salon   Salon   @relation(fields: [salonId], references: [id])
  service Service @relation(fields: [serviceId], references: [id])
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

model Payment {
  id             Int      @id @default(autoincrement())
  razorpayOrderId String   @unique
  razorpayPaymentId String?
  razorpaySignature String?
  amount         Float
  status         PaymentStatus @default(PENDING)
  userId         Int
  bookingId      Int?
  createdAt      DateTime @default(now())
}
